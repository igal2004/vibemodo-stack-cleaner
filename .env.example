INSTALLED_APP_SIGNATURES_JSON=[{"name":"Example App","domains":["cdn.example-app.com"],"signatures":["example-app"]}]
BACKUP_DIR=/data/backups
SCAN_RATE_LIMIT_MS=650
PORT=3000
